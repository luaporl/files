    local uiScaleObj = Instance.new("UIScale"); uiScaleObj.Scale = isMobile and 0.70 or 1.0

    local function makeDraggable(frame, handle)
        local src = handle or frame
        local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
        src.InputBegan:Connect(function(inp)
            if State.uiLocked then return end
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = inp.Position; startPos = frame.Position
                inp.Changed:Connect(function() if inp.UserInputState == Enum.UserInputState.End then dragging = false end end)
            end
        end)
        src.InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then dragInput = inp end
        end)
        UIS.InputChanged:Connect(function(inp)
            if inp == dragInput and dragging and not State.uiLocked then
                local dx = inp.Position.X - dragStart.X; local dy = inp.Position.Y - dragStart.Y
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + dx, startPos.Y.Scale, startPos.Y.Offset + dy)
            end
        end)
    end

    local function makeStackDraggable(frame, onTap)
        local dragStartPos, startPos, isDragging, movedEnough, pressTime, released = nil, nil, false, false, 0, false
        local dragInput = nil
        local function handleRelease()
            if released then return end; released = true
            isDragging = false
            if not movedEnough then
                if onTap then onTap() end
            elseif movedEnough then pcall(requestSave) end
        end
        frame.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
            released = false; isDragging = true; movedEnough = false; pressTime = tick()
            dragStartPos = input.Position; startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then handleRelease() end
            end)
        end)
        frame.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
        end)
        UIS.InputChanged:Connect(function(input)
            if input == dragInput and isDragging and not State.stackButtonsLocked then
                local delta = input.Position - dragStartPos
                if delta.Magnitude > 8 then movedEnough = true end
                if movedEnough then frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end
            end
        end)
        UIS.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
            if isDragging then handleRelease() end
