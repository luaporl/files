-- ============================================================
-- ANTI-DIE (built-in, always on)
-- Blocks Humanoid.Health = 0 from CharacterController anti-jump-spam
-- Blocks ragdoll-induced death
-- ============================================================
local antiDieConn = nil
local antiDieChildConns = {}
startAntiDie = function()
    if antiDieConn then return end
    local function hookHealth(hum)
        if not hum then return end
        antiDieConn = hum.HealthChanged:Connect(function(newHealth)
            if newHealth <= 0 and hum.MaxHealth > 0 then
                pcall(function() hum.Health = hum.MaxHealth end)
            end
        end)
    end
    local char = LP.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        hookHealth(hum)
        for _, c in ipairs(antiDieChildConns) do pcall(function() c:Disconnect() end) end
        antiDieChildConns = {}
        table.insert(antiDieChildConns, char.ChildAdded:Connect(function(c)
            if c:IsA("Humanoid") then task.wait(0.1); hookHealth(c) end
        end))
    end
end

stopAntiDie = function()
    if antiDieConn then antiDieConn:Disconnect(); antiDieConn = nil end
    for _, c in ipairs(antiDieChildConns) do pcall(function() c:Disconnect() end) end
    antiDieChildConns = {}
end

