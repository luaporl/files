-- AUTO TP (teleport down when above height)
-- ============================================================
local function doAutoTPDown(force)
    local char = LP.Character; if not char then return end
    local hrp2 = char:FindFirstChild("HumanoidRootPart"); if not hrp2 then return end
    local hum2 = char:FindFirstChildOfClass("Humanoid"); if not hum2 then return end
    if not force then
        if hum2.FloorMaterial ~= Enum.Material.Air then return end
        if hrp2.Position.Y < State.autoTPHeight then return end
    end
    hrp2.CFrame = CFrame.new(hrp2.Position.X, -7, hrp2.Position.Z) * CFrame.Angles(0, select(2, hrp2.CFrame:ToEulerAnglesYXZ()), 0)
    hrp2.AssemblyLinearVelocity = Vector3.zero
end
startAutoTP = function()
    if State.autoTPConn then task.cancel(State.autoTPConn); State.autoTPConn = nil end
    State.autoTPConn = task.spawn(function()
        while State.autoTPEnabled do task.wait(0.1); if not isDuelCountdownActive() then pcall(function() doAutoTPDown(false) end) end end
    end)
end
stopAutoTP = function()
    State.autoTPEnabled = false
    if State.autoTPConn then task.cancel(State.autoTPConn); State.autoTPConn = nil end
end
runTPDown = function() pcall(function() doAutoTPDown(true) end) end

