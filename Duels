-- ============================================================
local MEDUSA_RANGE = 9.5
local MEDUSA_USE_COOLDOWN = 0.12
local _autoMedusaConn = nil
local _autoMedusaAttacking = false
local function startAutoMedusa()
    if _autoMedusaConn then return end
    _autoMedusaConn = RunService.Heartbeat:Connect(function()
        if not State.autoMedusaEnabled then return end
        local char = LP.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
        local heldTool = char:FindFirstChildOfClass("Tool")
        if not heldTool then return end
        local toolName = heldTool.Name:lower()
        if not (toolName:find("medusa") or toolName:find("head") or toolName:find("stone")) then return end
        local enemyClose = false
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local tRoot = plr.Character:FindFirstChild("HumanoidRootPart")
