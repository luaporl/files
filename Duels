        TweenService:Create(switchBg, TweenInfo.new(0.2),
            {BackgroundColor3 = on and Color3.fromRGB(25, 50, 30) or Color3.fromRGB(40, 40, 46)}):Play()
        if on then
            State.laggerThread = task.spawn(startLaggerLoop)
        else
            pcall(function() game:GetService("NetworkClient"):SetOutgoingKBPSLimit(0) end)
            pcall(function() settings().Network.IncomingReplicationLag = 0 end)
            payloadCache = nil; payloadDepth = nil; payloadCopies = nil
            State.laggerThread = nil
        end
    end

    local function toggleLagger()
        setLaggerState(not State.laggerActive)
    end

    switchBg.MouseButton1Click:Connect(toggleLagger)

    local listeningFor = false; local listenStart = 0
    kbBtn.MouseButton1Click:Connect(function()
        if listeningFor then
            listeningFor = false; kbBtn.Text = getKeyDisplayName(State.laggerKeybind)
            kbBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 36); return
        end
        listeningFor = true; listenStart = tick(); kbBtn.Text = "..."
        kbBtn.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
    end)

    local isMinimized = false
    local function toggleMinimize()
        isMinimized = not isMinimized
        TweenService:Create(f, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            {Size = isMinimized and UDim2.new(0, PW, 0, 34) or UDim2.new(0, PW, 0, PH)}):Play()
        body.Visible = not isMinimized
    end

    closeBtn.MouseButton1Click:Connect(function()
        if State.laggerActive then setLaggerState(false) end
        TweenService:Create(f, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, PW, 0, 0)}):Play()
        task.wait(0.22); sg:Destroy(); State.laggerGui = nil
    end)
    minBtn.MouseButton1Click:Connect(toggleMinimize)

    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = f.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local d = input.Position - dragStart
            f.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)

    UIS.InputBegan:Connect(function(input, processed)
        if processed then return end
        if listeningFor then
            local isGp = isGamepadInput(input)
            if isGp and tick() - listenStart < 0.15 then return end
            if isBindableInput(input) then
                State.laggerKeybind = input.KeyCode; kbBtn.Text = getKeyDisplayName(input.KeyCode)
                kbBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 36); listeningFor = false
                requestSave()
            elseif input.KeyCode == Enum.KeyCode.Unknown and not isGp then
                listeningFor = false; kbBtn.Text = getKeyDisplayName(State.laggerKeybind)
                kbBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 36)
            end
        elseif input.KeyCode == State.laggerKeybind then toggleLagger() end
    end)

    TweenService:Create(f, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, PW, 0, PH)}):Play()
end

